</div>

<style>
  body.age-verification-active {
    overflow: hidden;
  }
  
  .age-verification-overlay {
    animation: fadeIn 0.5s ease-in-out;
  }
  
  .age-verification-modal {
    animation: slideIn 0.4s ease-out;
  }
  
  .fullscreen-content {
    animation: fadeInUp 0.6s ease-out;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  
  @keyframes slideIn {
    from { 
      opacity: 0;
      transform: translateY(-20px) scale(0.95);
    }
    to { 
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .slider-track:hover .slider-button {
    box-shadow: 0 6px 16px rgba(0,0,0,0.4);
  }
  
  .slider-button.active {
    left: calc(100% - 56px) !important;
  }
  
  .slider-button.active svg {
    display: none;
  }
  
  .slider-button.active::after {
    content: '';
    display: block;
    width: 24px;
    height: 24px;
    background-image: url("data:image/svg+xml,%3Csvg width='24' height='24' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M20 6L9 17L4 12' stroke='%2328a745' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: center;
    background-size: contain;
  }
  
  .slider-button.dragging {
    cursor: grabbing !important;
    transition: none !important;
  }
  
  #continue-button.enabled {
    background: rgba(40, 167, 69, 0.9) !important;
    opacity: 1 !important;
    pointer-events: auto !important;
  }
  
  #continue-button.enabled:hover {
    background: rgba(40, 167, 69, 1) !important;
    transform: translateY(-2px);
  }
  
  @media (max-width: 768px) {
    .age-verification-modal {
      padding: 30px 20px !important;
      margin: 20px !important;
    }
    
    .age-verification-buttons {
      flex-direction: column !important;
    }
    
    .age-verification-buttons button {
      width: 100% !important;
    }
    
    .fullscreen-content {
      padding: 20px !important;
    }
    
    .fullscreen-content h1 {
      font-size: 32px !important;
    }
    
    .age-slider-container {
      max-width: 100% !important;
    }
  }

  /* ========================================
     ESTILOS TEMÁTICOS PARA LICORES
     ======================================== */

  /* Base para todos los modales temáticos */
  .themed-modal {
    background: rgba(20, 20, 20, 0.95);
    border-radius: 16px;
    padding: 3rem 2.5rem;
    max-width: 480px;
    width: 90%;
    text-align: center;
    position: relative;
    overflow: hidden;
    animation: slideIn 0.5s ease-out;
  }

  .themed-logo {
    margin-bottom: 1.5rem;
  }

  .themed-logo img {
    max-width: 200px;
    height: auto;
  }

  .themed-badge {
    font-size: 0.75rem;
    letter-spacing: 3px;
    opacity: 0.7;
    margin-bottom: 0.5rem;
  }

  .themed-title {
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: 2px;
    margin-bottom: 0.5rem;
    line-height: 1.2;
    text-align: center;
  }

  .themed-subtitle {
    font-size: 1.15rem;
    opacity: 0.8;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .themed-divider {
    margin: 1.25rem 0;
    opacity: 0.6;
  }

  .themed-divider.decorative-line {
    height: 2px;
    width: 80px;
    margin-left: auto;
    margin-right: auto;
    background: linear-gradient(90deg, transparent, currentColor, transparent);
    opacity: 0.4;
  }

  .themed-message {
    font-size: 1.15rem;
    line-height: 1.6;
    opacity: 0.85;
    margin-bottom: 2rem;
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
  }

  .themed-buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .themed-btn {
    padding: 16px 44px;
    font-size: 1.1rem;
    font-weight: 600;
    border-radius: 30px;
    cursor: pointer;
    transition: all 0.3s ease;
    min-width: 260px;
    border: 2px solid transparent;
  }

  .themed-btn-confirm {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    color: white;
    border: none;
  }

  .themed-btn-confirm:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(40, 167, 69, 0.4);
  }

  .themed-btn-exit {
    background: transparent;
    color: rgba(255,255,255,0.7);
    border: 1px solid rgba(255,255,255,0.3);
  }

  .themed-btn-exit:hover {
    background: rgba(255,255,255,0.1);
    color: white;
  }

  .themed-footer {
    margin-top: 2rem;
    font-size: 0.8rem;
    opacity: 0.5;
    line-height: 1.4;
  }

  /* ========================================
     ESTILO: WHISKY PREMIUM
     ======================================== */
  .whisky-premium-modal {
    background: linear-gradient(180deg, rgba(58, 36, 12, 0.98) 0%, rgba(30, 18, 6, 0.98) 100%);
    border: 1px solid rgba(212, 175, 55, 0.3);
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.6), inset 0 1px 0 rgba(212, 175, 55, 0.2);
    color: #f5e6c8;
  }

  .whisky-premium-modal .themed-badge {
    color: #d4af37;
    border: 1px solid rgba(212, 175, 55, 0.4);
    padding: 4px 16px;
    border-radius: 20px;
    display: inline-block;
  }

  .whisky-premium-modal .themed-title {
    color: #d4af37;
    text-shadow: 0 2px 10px rgba(212, 175, 55, 0.3);
  }

  .whisky-premium-modal .themed-divider.decorative-line {
    background: linear-gradient(90deg, transparent, #d4af37, transparent);
  }

  .whisky-premium-modal .themed-btn-confirm {
    background: linear-gradient(135deg, #d4af37 0%, #b8860b 100%);
    color: #1a0f00;
  }

  .whisky-premium-modal .themed-btn-confirm:hover {
    box-shadow: 0 8px 30px rgba(212, 175, 55, 0.5);
  }

  .whisky-premium-modal .whisky-glass {
    position: absolute;
    top: -20px;
    right: -20px;
    width: 120px;
    height: 120px;
    background: radial-gradient(circle at 30% 30%, rgba(212, 175, 55, 0.15) 0%, transparent 60%);
    border-radius: 50%;
  }

  /* ========================================
     ESTILO: BODEGA DE VINOS
     ======================================== */
  .wine-cellar-modal {
    background: linear-gradient(180deg, rgba(74, 28, 46, 0.98) 0%, rgba(45, 15, 24, 0.98) 100%);
    border: 1px solid rgba(139, 69, 89, 0.4);
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.6);
    color: #f5e6e8;
  }

  .wine-cellar-modal .themed-title {
    color: #e8b4bc;
  }

  .wine-cellar-modal .themed-divider.decorative-line {
    background: linear-gradient(90deg, transparent, #c94c4c, transparent);
  }

  .wine-cellar-modal .themed-btn-confirm {
    background: linear-gradient(135deg, #722f37 0%, #8b4553 100%);
    color: white;
  }

  .wine-cellar-modal .themed-btn-confirm:hover {
    box-shadow: 0 8px 30px rgba(114, 47, 55, 0.5);
  }

  .wine-cellar-modal .wine-stain {
    position: absolute;
    top: -50px;
    left: -50px;
    width: 150px;
    height: 150px;
    background: radial-gradient(circle, rgba(139, 28, 46, 0.2) 0%, transparent 70%);
    border-radius: 50%;
  }

  .wine-cellar-modal .wine-cork-decoration {
    position: absolute;
    bottom: 20px;
    right: 20px;
    width: 30px;
    height: 50px;
    background: linear-gradient(180deg, #8b7355 0%, #6b5344 100%);
    border-radius: 4px;
    opacity: 0.3;
  }

  /* ========================================
     ESTILO: BAR TROPICAL
     ======================================== */
  .tropical-bar-modal {
    background: linear-gradient(180deg, rgba(32, 58, 67, 0.98) 0%, rgba(15, 32, 39, 0.98) 100%);
    border: 1px solid rgba(64, 224, 208, 0.3);
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.6);
    color: #e0f7fa;
  }

  .tropical-bar-modal .themed-title {
    color: #4dd0e1;
    text-shadow: 0 0 20px rgba(77, 208, 225, 0.3);
  }

  .tropical-bar-modal .themed-divider.decorative-line {
    background: linear-gradient(90deg, transparent, #4dd0e1, transparent);
  }

  .tropical-bar-modal .themed-btn-confirm {
    background: linear-gradient(135deg, #ff6b6b 0%, #ffa502 100%);
    color: white;
  }

  .tropical-bar-modal .themed-btn-confirm:hover {
    box-shadow: 0 8px 30px rgba(255, 107, 107, 0.5);
  }

  .tropical-bar-modal .tropical-leaves {
    position: absolute;
    width: 100px;
    height: 200px;
    opacity: 0.15;
  }

  .tropical-bar-modal .tropical-leaves.left {
    left: -30px;
    top: 50%;
    transform: translateY(-50%) rotate(-15deg);
    background: linear-gradient(45deg, #4caf50 0%, transparent 100%);
    border-radius: 0 100% 0 100%;
  }

  .tropical-bar-modal .tropical-leaves.right {
    right: -30px;
    top: 50%;
    transform: translateY(-50%) rotate(15deg);
    background: linear-gradient(-45deg, #4caf50 0%, transparent 100%);
    border-radius: 100% 0 100% 0;
  }

  /* ========================================
     ESTILO: CLUB NOCTURNO NEÓN
     ======================================== */
  .neon-club-modal {
    background: transparent;
    border: 2px solid transparent;
    box-shadow: 0 0 40px rgba(138, 43, 226, 0.3), 0 0 80px rgba(0, 255, 255, 0.1);
    color: #ffffff;
  }

  .neon-club-modal .neon-border {
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    border-radius: 18px;
    background: linear-gradient(45deg, #ff00ff, #00ffff, #ff00ff);
    z-index: -1;
    animation: neonPulse 3s ease-in-out infinite;
  }

  @keyframes neonPulse {
    0%, 100% { opacity: 0.7; }
    50% { opacity: 1; }
  }

  .neon-club-modal .neon-text {
    color: #fff;
    text-shadow: 0 0 10px #ff00ff, 0 0 20px #ff00ff, 0 0 40px #ff00ff;
    animation: neonFlicker 2s ease-in-out infinite;
  }

  @keyframes neonFlicker {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.8; }
  }

  .neon-club-modal .neon-divider.decorative-line {
    background: linear-gradient(90deg, transparent, #00ffff, transparent);
    box-shadow: 0 0 10px #00ffff;
  }

  .neon-club-modal .neon-btn {
    background: transparent;
    border: 2px solid #ff00ff;
    color: #ff00ff;
    box-shadow: 0 0 20px rgba(255, 0, 255, 0.3), inset 0 0 20px rgba(255, 0, 255, 0.1);
  }

  .neon-club-modal .neon-btn:hover {
    background: #ff00ff;
    color: #000;
    box-shadow: 0 0 40px rgba(255, 0, 255, 0.6);
  }

  .neon-club-modal .neon-glow img {
    filter: drop-shadow(0 0 10px rgba(255, 0, 255, 0.5));
  }

  /* ========================================
     ESTILO: ETIQUETA VINTAGE
     ======================================== */
  .vintage-label-modal {
    background: linear-gradient(180deg, #f5e6d3 0%, #e8d4b8 100%);
    border: 3px solid #8b7355;
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.4), inset 0 0 100px rgba(139, 115, 85, 0.1);
    color: #3d2914;
  }

  .vintage-label-modal .themed-title {
    color: #2c1810;
    font-family: Georgia, 'Times New Roman', serif;
    font-style: italic;
  }

  .vintage-label-modal .themed-subtitle {
    color: #5d4e37;
    font-family: Georgia, serif;
  }

  .vintage-label-modal .themed-message {
    color: #4a3c2a;
  }

  .vintage-label-modal .vintage-seal {
    width: 60px;
    height: 60px;
    border: 3px solid #8b4513;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    font-weight: bold;
    color: #8b4513;
    margin: 0 auto 1rem;
    background: rgba(139, 69, 19, 0.1);
  }

  .vintage-label-modal .vintage-ornament.decorative-line {
    background: linear-gradient(90deg, transparent, #8b7355, transparent);
    width: 100px;
  }

  .vintage-label-modal .themed-btn-confirm {
    background: linear-gradient(135deg, #8b4513 0%, #654321 100%);
    color: #f5e6d3;
  }

  .vintage-label-modal .themed-btn-exit {
    color: #5d4e37;
    border-color: #8b7355;
  }

  .vintage-label-modal .vintage-frame {
    position: absolute;
    top: 10px;
    left: 10px;
    right: 10px;
    bottom: 10px;
    border: 1px solid rgba(139, 115, 85, 0.4);
    border-radius: 8px;
    pointer-events: none;
  }

  .vintage-label-modal .vintage-corner {
    position: absolute;
    width: 20px;
    height: 20px;
    border: 2px solid #8b7355;
  }

  .vintage-label-modal .vintage-corner.top-left {
    top: -1px;
    left: -1px;
    border-right: none;
    border-bottom: none;
  }

  .vintage-label-modal .vintage-corner.top-right {
    top: -1px;
    right: -1px;
    border-left: none;
    border-bottom: none;
  }

  .vintage-label-modal .vintage-corner.bottom-left {
    bottom: -1px;
    left: -1px;
    border-right: none;
    border-top: none;
  }

  .vintage-label-modal .vintage-corner.bottom-right {
    bottom: -1px;
    right: -1px;
    border-left: none;
    border-top: none;
  }

  .vintage-label-modal .themed-footer {
    color: #5d4e37;
  }

  /* ========================================
     ESTILO: LUJO OSCURO
     ======================================== */
  .dark-luxury-modal {
    background: linear-gradient(180deg, rgba(26, 26, 26, 0.98) 0%, rgba(10, 10, 10, 0.98) 100%);
    border: 1px solid rgba(212, 175, 55, 0.4);
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.8), inset 0 1px 0 rgba(212, 175, 55, 0.1);
    color: #e0e0e0;
  }

  .dark-luxury-modal .luxury-pattern {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 10px,
      rgba(212, 175, 55, 0.03) 10px,
      rgba(212, 175, 55, 0.03) 20px
    );
    pointer-events: none;
  }

  .dark-luxury-modal .luxury-emblem {
    font-size: 0.85rem;
    letter-spacing: 6px;
    color: #d4af37;
    margin-bottom: 0.75rem;
    font-weight: 600;
    text-shadow: 0 0 10px rgba(212, 175, 55, 0.5);
    border: 1px solid rgba(212, 175, 55, 0.4);
    padding: 6px 20px;
    display: inline-block;
    border-radius: 4px;
  }

  .dark-luxury-modal .gold-text {
    background: linear-gradient(135deg, #d4af37 0%, #f5e6c8 50%, #d4af37 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-shadow: none;
  }

  .dark-luxury-modal .gold-divider {
    height: 2px;
    width: 100px;
    background: linear-gradient(90deg, transparent, #d4af37, transparent);
    margin: 1.5rem auto;
  }

  .dark-luxury-modal .gold-btn {
    background: linear-gradient(135deg, #d4af37 0%, #b8860b 100%);
    color: #0a0a0a;
    font-weight: 700;
  }

  .dark-luxury-modal .gold-btn:hover {
    box-shadow: 0 8px 30px rgba(212, 175, 55, 0.4);
  }

  .dark-luxury-modal .themed-btn-exit {
    border-color: rgba(212, 175, 55, 0.4);
    color: rgba(212, 175, 55, 0.8);
  }

  .dark-luxury-modal .themed-btn-exit:hover {
    background: rgba(212, 175, 55, 0.1);
    color: #d4af37;
  }

  /* ========================================
     RESPONSIVE PARA TEMAS
     ======================================== */
  @media (max-width: 768px) {
    .themed-modal {
      padding: 2rem 1.5rem;
      margin: 1rem;
      max-width: calc(100% - 2rem);
    }

    .themed-title {
      font-size: 1.6rem;
    }

    .themed-subtitle {
      font-size: 1rem;
    }

    .themed-message {
      font-size: 1rem;
    }

    .themed-btn {
      min-width: 100%;
      padding: 14px 30px;
      font-size: 1rem;
    }

    .themed-buttons {
      width: 100%;
    }
  }
</style>

<script>
  let sliderActive = false;
  let isDragging = false;
  let startX = 0;
  let currentX = 0;
  let sliderButton = null;
  let sliderTrack = null;
  
  // Verificar si el usuario ya confirmó su edad (24 horas)
  function checkAgeVerification() {
    const ageVerifiedTime = localStorage.getItem('age_verified_time');
    const modal = document.getElementById('age-verification-modal');
    
    if (ageVerifiedTime) {
      const timeElapsed = Date.now() - parseInt(ageVerifiedTime);
      const twentyFourHours = 24 * 60 * 60 * 1000; // 24 horas en milisegundos
      
      if (timeElapsed < twentyFourHours && modal) {
        document.body.classList.remove('age-verification-active');
        modal.style.display = 'none';
        return;
      } else {
        // Han pasado más de 24 horas, limpiar storage
        localStorage.removeItem('age_verified_time');
      }
    }
    
    // Mostrar modal si no hay verificación válida
    if (modal) {
      modal.style.display = 'flex';
      document.body.classList.add('age-verification-active');
    }
  }

  function confirmAge() {
    // Guardar timestamp actual (24 horas de duración)
    localStorage.setItem('age_verified_time', Date.now().toString());
    
    const modal = document.getElementById('age-verification-modal');
    if (modal) {
      modal.style.animation = 'fadeOut 0.4s ease-in-out';
      setTimeout(() => {
        document.body.classList.remove('age-verification-active');
        modal.style.display = 'none';
      }, 300);
    }
  }

  function exitSite() {
    
      window.location.href = 'https://www.google.com';
    
  }

  function closeAgeVerification() {
    
  }
  
  // Funciones para el slider deslizable
  function getEventX(e) {
    return e.type.includes('mouse') ? e.clientX : e.touches[0].clientX;
  }
  
  function startDrag(e) {
    
  }
  
  function onDrag(e) {
    
  }
  
  function endDrag(e) {
    
  }
  
  function activateSlider() {
    
  }
  
  function initializeSlider() {
    
  }

  // CSS para animación de salida
  const style = document.createElement('style');
  style.textContent = `
    @keyframes fadeOut {
      from { opacity: 1; }
      to { opacity: 0; }
    }
  `;
  document.head.appendChild(style);

  // Ejecutar verificación cuando el DOM esté listo
  document.addEventListener('DOMContentLoaded', function() {
    checkAgeVerification();
    initializeSlider();
    
    // Restaurar overflow si ya estaba verificado
    const ageVerifiedTime = localStorage.getItem('age_verified_time');
    if (ageVerifiedTime) {
      const timeElapsed = Date.now() - parseInt(ageVerifiedTime);
      const twentyFourHours = 24 * 60 * 60 * 1000;
      
      if (timeElapsed < twentyFourHours) {
        document.documentElement.style.overflow = '';
      }
    }
  });
  
  // También verificar cuando se navega hacia atrás/adelante
  window.addEventListener('pageshow', function() {
    checkAgeVerification();
    initializeSlider();
  });
