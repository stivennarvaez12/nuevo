</section><section id="shopify-section-template--19740659646603__collection-list" class="shopify-section cc-collection-list"><div class="section color-scheme--transparent"><div class="container">
      <div class="section__header items-center flex flex-row flex-wrap gap-x-theme" data-cc-animate><h2 class="h4 mb-0 flex-auto text-start">Encuentra lo que te falta</h2></div>
    </div><carousel-slider class="carousel block"inactive>
      <div class="container relative">
        <div class="slider" id="slider-template--19740659646603__collection-list"><div class="container">
