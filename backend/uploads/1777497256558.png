          <style>
            .wishlist-button-wrapper {
              display: inline-block;
            }

            .wishlist-btn {
              display: flex;
              align-items: center;
              gap: 0.5rem;
              padding: 0.5rem 1rem;
              border: 1px solid #e5e5e5;
              background: transparent;
              border-radius: 4px;
              cursor: pointer;
              transition: all 0.2s ease;
              font-size: 1.575rem;
