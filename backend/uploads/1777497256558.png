              data-product-image="//licoresmedellin.com/cdn/shop/files/licor-de-ron-viejo-de-caldas-esencial-litro-1llicor-de-ron-viejo-de-caldas-esencial-litro-1lron-viejo-de-caldaslicores-medellin-3421446.jpg?v=1771440367&width=300"
